{
  "description": "Monorepo for Veil projects (react-veil library and docs)",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.5.0",
    "typescript": "^5.9.3"
  },
  "name": "veil-monorepo",
  "private": true,
  "scripts": {
    "build:docs": "npm run build --workspace=docs",
    "build:lib": "npm run build --workspace=react-veil",
    "deploy:docs": "npm run deploy --workspace=docs",
    "dev:docs": "npm run dev --workspace=docs",
    "lint": "eslint .",
    "test": "npm test --workspace=react-veil --if-present",
    "typecheck": "npm run typecheck --workspace=react-veil && npm run typecheck --workspace=docs"
  },
  "type": "module",
  "version": "0.1.2",
  "workspaces": [
    "docs",
    "react-veil"
  ]
}
